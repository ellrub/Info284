    "f1_med_history, f1_med_model = make_model(F1Score(threshold=medium_th, average='micro'), x_tr_frog, y_tr_frog, x_te_frog, y_te_frog)\n",
    "\n",
    "f1_hi_history, f1_hi_model = make_model(F1Score(threshold=high_th, average='micro'), x_tr_frog, y_tr_frog, x_te_frog, y_te_frog)"
